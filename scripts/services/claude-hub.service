[Unit]
Description=claude-hub MCP Server
After=network.target postgresql.service

[Service]
Type=simple
User=claude
Group=claude
WorkingDirectory=/home/claude/deploy/claude-hub
Environment=PATH=/home/claude/.local/bin:/home/claude/deploy/claude-hub/venv/bin:/usr/local/bin:/usr/bin:/bin
Environment=CLAUDE_HUB_PROJECT_DIR=/home/claude/deploy/claude-hub
Environment=HOME=/home/claude
EnvironmentFile=/etc/claude-hub/claude-hub.env
ExecStart=/home/claude/deploy/claude-hub/venv/bin/uvicorn claude_hub.server:app --host 127.0.0.1 --port 8420
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
MemoryMax=2G
MemoryHigh=1536M

[Install]
WantedBy=multi-user.target
